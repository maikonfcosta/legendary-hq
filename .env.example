# URL base para os manuais em PDF (Firebase)
# Caso utilize o Firebase Storage, substitua <seu-projeto> pelo ID do projeto e certifique-se de que a pasta /docs é pública, ou, alternativamente, coloque os PDFs no Firebase Hosting.
VITE_PDF_BASE_URL=https://firebasestorage.googleapis.com/v0/b/<seu-projeto>.appspot.com/o/docs

# Credenciais do Firebase (Firebase Console -> Project Settings -> General -> Web App)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
