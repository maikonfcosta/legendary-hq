# URL base para os manuais em PDF (Firebase)
# Caso utilize o Firebase Storage, substitua <seu-projeto> pelo ID do projeto e certifique-se de que a pasta /docs é pública, ou, alternativamente, coloque os PDFs no Firebase Hosting.
VITE_PDF_BASE_URL=https://firebasestorage.googleapis.com/v0/b/<seu-projeto>.appspot.com/o/docs
